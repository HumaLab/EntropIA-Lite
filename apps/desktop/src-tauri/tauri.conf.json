{
  "productName": "EntropIA Lite",
  "version": "1.0.2",
  "identifier": "com.entropia.lite",
  "build": {
    "beforeDevCommand": "pnpm --filter @entropia/desktop dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EntropIA Lite",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "fragmentPaths": ["./windows/fragments/force-webview2-bootstrapper.wxs"],
        "componentRefs": [
          "ForceWebView2BootstrapperHook",
          "AppLocalConcrt140",
          "AppLocalMsvcp140",
          "AppLocalMsvcp1401",
          "AppLocalVcomp140",
          "AppLocalVcruntime140",
          "AppLocalVcruntime1401"
        ]
      },
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "resources": ["resources/*"]
  }
}
