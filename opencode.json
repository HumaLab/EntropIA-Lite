{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "tauri": {
      "type": "local",
      "command": ["npx", "-y", "@hypothesi/tauri-mcp-server"],
      "enabled": true,
      "timeout": 60000
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "timeout": 60000
    },
    "shadcn": {
      "type": "local",
      "command": ["pnpm", "dlx", "shadcn@latest", "mcp", "--cwd", "apps/desktop"],
      "enabled": true,
      "timeout": 90000
    }
  }
}
